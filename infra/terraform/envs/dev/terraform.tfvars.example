aws_profile = "hf-dev"
aws_region  = "ap-southeast-2"

project     = "hms"
environment = "dev"

github_repository = "janisyed18/hms-2.0"
github_deploy_refs = [
  "repo:janisyed18/hms-2.0:environment:aws-dev",
  "repo:janisyed18/hms-2.0:ref:refs/heads/main",
  "repo:janisyed18/hms-2.0:ref:refs/heads/codex/aws-dev-deployment-foundation",
]

# Dev-sized defaults. Increase before staging/production.
db_instance_class          = "db.t4g.micro"
redis_node_type            = "cache.t4g.micro"
api_desired_count          = 1
worker_desired_count       = 1
beat_desired_count         = 1
enable_deletion_protection = false

# Keep console until the SES sender is verified and Twilio secrets exist.
notification_channel_mode = "console"

# AWS dev uses the SES API through the ECS task role. The SMTP values remain
# available only if notification_email_provider is changed to "smtp".
notification_email_provider = "aws_ses"
notification_smtp_host      = "email-smtp.ap-southeast-2.amazonaws.com"
notification_smtp_port      = 587
notification_smtp_use_tls   = true

# Replace with the real SES-verified sender before switching to live.
notification_email_from_address = "no-reply@hftechnologies.com.au"

# Set true when you want Terraform to create the SES email identity and trigger
# the verification email for notification_email_from_address.
notification_create_ses_email_identity = true
