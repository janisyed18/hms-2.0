aws_profile = "hf-dev"
aws_region  = "ap-southeast-2"

project     = "hms"
environment = "dev"

github_repository = "janisyed18/hms-2.0"
github_deploy_refs = [
  "repo:janisyed18/hms-2.0:ref:refs/heads/main",
  "repo:janisyed18/hms-2.0:ref:refs/heads/codex/aws-dev-deployment-foundation",
]

# Dev-sized defaults. Increase before staging/production.
db_instance_class          = "db.t4g.micro"
redis_node_type            = "cache.t4g.micro"
api_desired_count          = 1
worker_desired_count       = 1
beat_desired_count         = 1
enable_deletion_protection = false

# Keep console until SES SMTP and Twilio secrets have real values in Secrets Manager.
notification_channel_mode = "console"

# AWS SES SMTP defaults for ap-southeast-2. Replace the From address with a
# verified SES identity before switching notification_channel_mode to "live".
notification_smtp_host         = "email-smtp.ap-southeast-2.amazonaws.com"
notification_smtp_port         = 587
notification_smtp_use_tls      = true
notification_email_from_address = "no-reply@batengineering.example"

# Set true only when you want Terraform to create the SES email identity and
# trigger the verification email for notification_email_from_address.
notification_create_ses_email_identity = false
