# Certificate engine configuration (copy to .env for local overrides).
# All variables are optional; the defaults below run a signed local dev service.

# gRPC server
HMS_CERT_HOST=127.0.0.1
HMS_CERT_PORT=50051

# Signing
HMS_CERT_SIGNING_ENABLED=true
HMS_CERT_DEV_AUTOGENERATE_SIGNER=true
# Production: point these at OCI Vault-sourced material and disable autogeneration.
# HMS_CERT_DEV_AUTOGENERATE_SIGNER=false
# HMS_CERT_SIGNING_CERT_PATH=/secrets/cert.pem
# HMS_CERT_SIGNING_KEY_PATH=/secrets/key.pem
# HMS_CERT_SIGNING_CHAIN_PATH=/secrets/chain.pem
# HMS_CERT_SIGNING_KEY_PASSPHRASE=

# Issuer identity printed on certificates
HMS_CERT_ISSUER_NAME=BAT Engineering Pty Ltd
HMS_CERT_ISSUER_ADDRESS=Melbourne, Victoria, Australia
HMS_CERT_ISSUER_CONTACT=certificates@batengineering.example
HMS_CERT_ISSUER_IDENTIFIER=ABN 00 000 000 000
