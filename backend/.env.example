APP_NAME="BAT Engineering HMS 2.0 API"
ENVIRONMENT=local
DATABASE_URL=sqlite+aiosqlite:///./hms_dev.db
AUTH_MODE=bearer
AUTH_DEV_HEADERS_ENABLED=false
AUTH_DEV_ALLOW_ROLE_FALLBACK=false
AUTH_BROWSER_LOGIN_ENABLED=true
# Generate each value independently. Never reuse development values in a
# shared, staging, or production environment.
AUTH_BEARER_HMAC_SECRET=
AUTH_BEARER_ISSUER=
AUTH_BEARER_AUDIENCE=
AUTH_MFA_ENCRYPTION_KEY=
AUTH_MFA_KEY_VERSION=1
AUTH_RECOVERY_CODE_PEPPER=
AUTH_BROWSER_ALLOWED_ORIGINS=["http://127.0.0.1:5173"]
AUTH_BROWSER_COOKIE_SECURE=false
