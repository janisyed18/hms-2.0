APP_NAME="BAT Engineering HMS 2.0 API"
ENVIRONMENT=local
DATABASE_URL=sqlite+aiosqlite:///./hms_dev.db
AUTH_MODE=dev
AUTH_DEV_HEADERS_ENABLED=true
AUTH_DEV_ALLOW_ROLE_FALLBACK=true
# Use AUTH_MODE=bearer outside local development and set a secret via your
# deployment secret manager.
AUTH_BEARER_HMAC_SECRET=
AUTH_BEARER_ISSUER=
AUTH_BEARER_AUDIENCE=
